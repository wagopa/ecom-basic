# Server
SERVER_PORT=8080

# Frontend (static storefront + admin, served by nginx)
FRONTEND_PORT=8081
# Must be reachable from the user's browser (not the internal Docker network name)
API_BASE_URL=http://localhost:8080/api

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=ecommerce_db
DB_USERNAME=ecommerce_user
DB_PASSWORD=ecommerce_pass
DB_ROOT_PASSWORD=root_pass
DB_POOL_SIZE=10

# JWT
JWT_SECRET=please_change_this_to_a_long_random_secret_at_least_256_bits
JWT_EXPIRATION=86400000

# Default admin account (seeded on startup if not exists)
ADMIN_EMAIL=admin@ecommerce.com
ADMIN_PASSWORD=Admin@123
ADMIN_FULL_NAME=System Administrator
